{
  "info": {
    "name": "Hikvision Attendance - On Duty API",
    "description": "API collection for managing On Duty records in the Hikvision Attendance system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Authenticate and get JWT token for API access"
          },
          "response": []
        }
      ],
      "description": "Authentication endpoints to get JWT token for API access"
    },
    {
      "name": "On Duty Management",
      "item": [
        {
          "name": "Create On Duty Record",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"startDate\": \"2025-10-15T00:00:00.000Z\",\n    \"endDate\": \"2025-10-16T23:59:59.999Z\",\n    \"description\": \"Conference attendance\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/institutions/{{institutionId}}/users/{{userId}}/on-duty",
              "host": ["{{baseUrl}}"],
              "path": ["api", "institutions", "{{institutionId}}", "users", "{{userId}}", "on-duty"]
            },
            "description": "Create a new On Duty record for a specific user"
          },
          "response": []
        },
        {
          "name": "Get User On Duty Records",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/institutions/{{institutionId}}/users/{{userId}}/on-duty",
              "host": ["{{baseUrl}}"],
              "path": ["api", "institutions", "{{institutionId}}", "users", "{{userId}}", "on-duty"]
            },
            "description": "Get all On Duty records for a specific user"
          },
          "response": []
        },
        {
          "name": "Get Institution On Duty Records",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/institutions/{{institutionId}}/on-duty?startDate={{startDate}}&endDate={{endDate}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "institutions", "{{institutionId}}", "on-duty"],
              "query": [
                {
                  "key": "startDate",
                  "value": "{{startDate}}",
                  "description": "Optional filter for start date (YYYY-MM-DD)"
                },
                {
                  "key": "endDate",
                  "value": "{{endDate}}",
                  "description": "Optional filter for end date (YYYY-MM-DD)"
                }
              ]
            },
            "description": "Get all On Duty records for an institution with optional date filtering"
          },
          "response": []
        },
        {
          "name": "Update On Duty Record",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"startDate\": \"2025-10-15T00:00:00.000Z\",\n    \"endDate\": \"2025-10-17T23:59:59.999Z\",\n    \"description\": \"Extended conference attendance\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/institutions/{{institutionId}}/on-duty/{{onDutyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "institutions", "{{institutionId}}", "on-duty", "{{onDutyId}}"]
            },
            "description": "Update an existing On Duty record"
          },
          "response": []
        },
        {
          "name": "Delete On Duty Record",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/institutions/{{institutionId}}/on-duty/{{onDutyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "institutions", "{{institutionId}}", "on-duty", "{{onDutyId}}"]
            },
            "description": "Delete an On Duty record"
          },
          "response": []
        }
      ],
      "description": "Endpoints for managing On Duty records"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000",
      "type": "string",
      "description": "Base URL for the API"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT token from login response"
    },
    {
      "key": "institutionId",
      "value": "",
      "type": "string",
      "description": "ID of the institution"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string",
      "description": "ID of the user"
    },
    {
      "key": "onDutyId",
      "value": "",
      "type": "string",
      "description": "ID of the On Duty record"
    },
    {
      "key": "startDate",
      "value": "2025-10-01",
      "type": "string",
      "description": "Start date for filtering (YYYY-MM-DD)"
    },
    {
      "key": "endDate",
      "value": "2025-10-31",
      "type": "string",
      "description": "End date for filtering (YYYY-MM-DD)"
    }
  ]
}