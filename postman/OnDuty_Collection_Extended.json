									"pm.test(\"Response has correct data\", function () {",
									"    pm.expect(jsonData.userId).to.equal(pm.environment.get(\"user_id\"));",
									"    pm.expect(jsonData.institutionId).to.equal(pm.environment.get(\"institution_id\"));",
