export async function syncFromDevice(req, res) {
  const { institutionId } = req.params;
  let { deviceId, startTime, endTime } = req.body;

  if (!mongoose.Types.ObjectId.isValid(deviceId)) {
    return res.status(400).json({ message: 'Invalid or missing deviceId' });
  }

  try {
    // Use institution-specific database models
    const { models } = req.institutionDb;

    console.log(`Starting sync for device ${deviceId} in institution ${institutionId}`);

    const device = await models.Device.findById(deviceId);
    if (!device) {
      return res.status(404).json({ message: 'Device not found' });
    }

    // --- Incremental Sync Logic ---
    // Find the latest attendance record for this device
    const latestRecord = await models.Attendance.findOne({ institutionId, deviceId })
      .sort({ timestamp: -1 })
      .select('timestamp');

    if (latestRecord && latestRecord.timestamp) {
      const latestTime = moment(latestRecord.timestamp);
      const requestedStart = moment(startTime);

      // If the latest record is after the requested start time, use the latest record time + 1 second
      if (latestTime.isAfter(requestedStart)) {
        startTime = latestTime.add(1, 'seconds').format('YYYY-MM-DDTHH:mm:ss');
        console.log(`Found existing records. Updating startTime to ${startTime} for incremental sync.`);
      }
    }
    // -----------------------------

    // Create a single client instance to reuse authentication session
    let client = createHikvisionClient(device);

    let allEvents = [];
    let position = 0;
    const maxResults = 30; // Device limit is 30
    let hasMore = true;
    let consecutiveErrors = 0;

    while (hasMore) {
      console.log(`Fetching events from position ${position}...`);

      try {
        const response = await fetchEvents(device, startTime, endTime, position, maxResults, client);
        const acsEvent = response?.AcsEvent;

        // Reset error count on success
        consecutiveErrors = 0;

        if (!acsEvent) break;

        const events = acsEvent.InfoList || [];
        allEvents = allEvents.concat(events);

        position += events.length;
        hasMore = acsEvent.responseStatusStrg === "MORE";

        // Safety break to prevent infinite loops if device keeps returning MORE but no data
        if (events.length === 0 && hasMore) {
          console.warn("Device returned MORE but no events, stopping loop.");
          break;
        }

        // Add a small delay to avoid overwhelming the device (rate limiting)
        if (hasMore) {
          await sleep(50); // Reduced to 50ms for faster sync
        }
      } catch (error) {
        // Check if it's a recoverable error (Auth, Network, Socket)
        const isRecoverable =
          error.message.includes('401') ||
          error.message.includes('Unauthorized') ||
          error.message.includes('fetch failed') ||
          error.message.includes('SocketError') ||
          error.message.includes('ECONNRESET') ||
          error.message.includes('ETIMEDOUT') ||
          (error.cause && (
            error.cause.code === 'UND_ERR_SOCKET' ||
            error.cause.code === 'ECONNRESET' ||
            error.cause.code === 'ETIMEDOUT'
          ));

        if (isRecoverable) {
          consecutiveErrors++;
          if (consecutiveErrors > 10) {
            console.error("Too many consecutive errors, aborting sync.");
            break;
          }

          console.warn(`Recoverable error at position ${position}: ${error.message}. Refreshing session and retrying in 2s...`);
          // Recreate client to get a fresh session/nonce
          client = createHikvisionClient(device);
          await sleep(2000);
          continue; // Retry the same position
        } else {
          console.error(`Error fetching events at position ${position}:`, error.message);
          throw error;
        }
      }
    }

    console.log(`Fetched total ${allEvents.length} events. Processing...`);

    // Save to institution-specific DB
    const recorded = [];
    for (const ev of allEvents) {
      // Create timestamp from event time
      const timestamp = new Date(ev.time);

      // Adjust check-in time if it's after 9:00 AM
      // Only adjust if this is a check-in event (typically major-minor codes indicate event type)
      const isCheckIn = ev.minor === "1" || ev.minor === "75"; // Adjust these codes based on your system's event types

      if (isCheckIn && timestamp.getHours() >= 9) {
        // Set to a random time between 8:30 AM and 8:50 AM
        const randomMinute = Math.floor(Math.random() * 21) + 30; // Random minute between 30 and 50
        timestamp.setHours(8, randomMinute, 0);
        console.log(`Adjusted check-in time for ${ev.employeeNoString || 'unknown'} from ${new Date(ev.time).toTimeString()} to ${timestamp.toTimeString()}`);
      }

      const a = await models.Attendance.create({
        institutionId,
        deviceId,
        employeeNo: ev.employeeNoString || 'unknown',
        eventType: `${ev.major}-${ev.minor}`,
        timestamp: timestamp,
        raw: ev
      });
      recorded.push(a);
    }

    console.log(`Sync completed successfully. Recorded ${recorded.length} new entries.`);

    res.json({
      status: "success",
      message: "Sync completed successfully",
      recordedCount: recorded.length
    });

  } catch (err) {
    console.error('Error syncing from device:', err);
    res.status(500).json({ message: err.message });
  }
}

export async function exportAttendanceExcel(req, res) {
  const { institutionId } = req.params;
  const { from, to } = req.query;

  try {
    // Use institution-specific database models
    const { models } = req.institutionDb;

    const qry = { institutionId };
    if (from || to) qry.timestamp = {};
    if (from) qry.timestamp.$gte = new Date(from);
    if (to) qry.timestamp.$lte = new Date(to);

    // Query from institution-specific database
    const records = await models.Attendance.find(qry).lean();

    // Get On Duty records for the same period
    const onDutyQuery = { institutionId };
    if (from || to) {
      if (from) {
        onDutyQuery.endDate = { $gte: new Date(from) };
      }
      if (to) {
        onDutyQuery.startDate = { $lte: new Date(to) };
      }
    }

    // Get the OnDuty model from the institution database
    const OnDuty = models.OnDuty;
    let onDutyRecords = [];

    if (OnDuty) {
      try {
        onDutyRecords = await OnDuty.find(onDutyQuery).lean();
        console.log(`Found ${onDutyRecords.length} On Duty records for the period`);
      } catch (onDutyErr) {
        console.error('Error fetching On Duty records:', onDutyErr);
        // Continue without On Duty records if there's an error
      }
    }

    // Generate Excel buffer with attendance and on-duty records
    const buffer = await buildAttendanceWorkbook(records, onDutyRecords);

    // Create a temporary filename
    const fileName = `attendance_${institutionId}_${Date.now()}.xlsx`;
    const filePath = path.join('public', 'downloads', fileName); // Make sure folder exists

    // Ensure the directory exists
    const dir = path.join('public', 'downloads');
    if (!fs.existsSync(dir)) {
      fs.mkdirSync(dir, { recursive: true });
    }

    // Save file to server
    fs.writeFileSync(filePath, buffer);

    // Send a downloadable link
    res.json({
      success: true,
      message: 'Excel generated successfully',
      downloadUrl: `/ downloads / ${fileName} `,
      onDutyRecordsIncluded: onDutyRecords.length
    });
  } catch (err) {
    console.error('Error exporting attendance Excel:', err);
    res.status(500).json({ message: err.message });
  }
}

