                "{{institutionId}}",
                "users",
                "{{userId}}",
                "leaves"
              ]
            },
            "description": "Get all leave requests for a specific user"
          },
          "response": []
        },
        {
          "name": "Approve Leave Request",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"comments\": \"Approved\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/institutions/{{institutionId}}/leaves/{{leaveId}}/approve",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "institutions",
                "{{institutionId}}",
                "leaves",
                "{{leaveId}}",
                "approve"
              ]
            },
            "description": "Approve a leave request"
          },
          "response": []
        },
        {
          "name": "Reject Leave Request",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"comments\": \"Insufficient notice period\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/institutions/{{institutionId}}/leaves/{{leaveId}}/reject",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "institutions",
                "{{institutionId}}",
                "leaves",
                "{{leaveId}}",
                "reject"
              ]
            },
            "description": "Reject a leave request"
          },
          "response": []
        },
        {
          "name": "Delete Leave Request",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/institutions/{{institutionId}}/leaves/{{leaveId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "institutions",
                "{{institutionId}}",
                "leaves",
                "{{leaveId}}"
              ]
            },
            "description": "Delete a leave request"
          },
          "response": []
        },
        {
          "name": "Download Leave Template",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/institutions/{{institutionId}}/leave-template",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "institutions",
                "{{institutionId}}",
                "leave-template"
              ]
            },
            "description": "Download Excel template for bulk leave upload"
          },
          "response": []
        },
        {
          "name": "Upload Leave Requests (Excel)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "{{leaveFile}}"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/institutions/{{institutionId}}/upload-leaves",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "institutions",
                "{{institutionId}}",
                "upload-leaves"
              ]
            },
            "description": "Bulk upload leave requests from Excel file\n\nRequired columns: EmployeeNo, LeaveDate, Type, Reason\nTypes: half-day-morning or half-day-afternoon"
          },
          "response": []
        }
      ]
    },
