{
  "info": {
    "name": "HIK Attendance - Leave & Permission Management",
    "description": "API collection for Leave Management (Half-day leaves) and Permission Management (1-hour permissions)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Leave Management",
      "item": [
        {
          "name": "Create Leave Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"leaveDate\": \"2025-12-15\",\n  \"type\": \"half-day-morning\",\n  \"reason\": \"Medical appointment\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/institutions/{{institutionId}}/leaves",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "institutions",
                "{{institutionId}}",
                "leaves"
              ]
            },
            "description": "Create a new leave request (half-day-morning or half-day-afternoon)"
          },
          "response": []
        },
        {
          "name": "Get All Leave Requests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/institutions/{{institutionId}}/leaves?status=pending&startDate=2025-12-01&endDate=2025-12-31",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "institutions",
                "{{institutionId}}",
                "leaves"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "pending",
                  "disabled": false
                },
                {
                  "key": "userId",
                  "value": "{{userId}}",
                  "disabled": true
                },
                {
                  "key": "startDate",
                  "value": "2025-12-01",
                  "disabled": true
                },
                {
                  "key": "endDate",
                  "value": "2025-12-31",
                  "disabled": true
                }
              ]
            },
            "description": "Get all leave requests with optional filters (status, userId, date range)"
          },
          "response": []
        },
        {
          "name": "Get User Leave Requests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/institutions/{{institutionId}}/users/{{userId}}/leaves",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
