									"key": "period",
									"value": "{{period}}",
									"description": "Optional period parameter: day, week, month, year (default: month)"
								}
							]
						},
						"description": "Get detailed attendance statistics for a specific user.\n\n**Response includes:**\n- User details (name, employee number)\n- Attendance percentage\n- Days present/absent\n- Average arrival time\n- Late day count\n- Daily attendance records with entry/exit times\n\n**Note:** This API uses the user's employee number to find attendance records."
