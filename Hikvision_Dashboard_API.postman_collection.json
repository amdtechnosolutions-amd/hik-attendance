		{
			"name": "Dashboard",
			"item": [
				{
					"name": "Get Dashboard Data",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://localhost:4000/api/institutions/{{institutionId}}/dashboard?date={{date}}&period={{period}}",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "4000",
							"path": [
								"api",
								"institutions",
								"{{institutionId}}",
								"dashboard"
							],
							"query": [
								{
									"key": "date",
									"value": "{{date}}",
									"description": "Optional date parameter in YYYY-MM-DD format"
								},
								{
									"key": "period",
									"value": "{{period}}",
									"description": "Optional period parameter: day, week, month, year (default: month)"
								}
							]
						},
						"description": "Get comprehensive dashboard data for an institution, including attendance statistics, user counts, and analytics.\n\n**Response includes:**\n- Total user and device counts\n- Today's attendance summary (present/absent counts and percentages)\n- Period-based attendance data\n- List of absent users\n- List of late comers\n- Hourly attendance trends\n- Top punctual users\n- Most consistent attendees\n\n**Note:** This API uses employee numbers to match attendance records with users."
					},
					"response": []
				},
				{
					"name": "Get Dashboard Data (Today)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://localhost:4000/api/institutions/{{institutionId}}/dashboard?period=day",
							"protocol": "http",
